{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "addLabels": [
    "renovate"
  ],
  "rangeStrategy": "pin",
  "minimumReleaseAge": "7 days",
  "rollbackPrs": true,
  "packageRules": [
    {
      "description": "Cargo LFM disabled because of https://github.com/renovatebot/renovate/issues/41659",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "enabled": false
    }
  ]
}
